{
    "name": "Koha Setup Test Env",
    "dockerFile": "Dockerfile",
    "features": {
        "ghcr.io/devcontainers/features/common-utils:2": {
            "installZsh": true,
            "username": "vscode",
            "userUid": "1000",
            "userGid": "1000",
            "upgradePackages": true
        },
        "ghcr.io/devcontainers/features/git:1": {}
    },
    // Install shellcheck and dependencies
    "postCreateCommand": "sudo apt-get update && sudo apt-get install -y shellcheck curl gnupg2 lsb-release",
    "remoteUser": "vscode",
    "runArgs": [
        "--privileged"
    ]
}
